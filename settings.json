      "Bash(docker volume rm *)",
      "Bash(docker volume prune *)",

      "Bash(npm publish *)",
      "Bash(npm unpublish *)",
      "Bash(pip uninstall *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/credentials)",
      "Read(**/secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",

      "Edit(.env)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(~/.aws/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.config/gcloud/**)",

      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)"
    ]
  
}
}
