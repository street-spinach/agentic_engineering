{
  "_comment": "Deterministic hook wiring (never calls a model): lint-dispatch.sh (lint lane) + test-runner.sh (unit-test lane). This file lives at the agentic_eng artefact-library root. To activate it for a project, merge this 'hooks' block into that project's .claude/settings.json (or ~/.claude/settings.json), or symlink it. Paths use $CLAUDE_PROJECT_DIR; if a script lives elsewhere than the active project root, swap in its absolute path. The two scripts share the PreToolUse Bash commit gate but own separate lanes (lint vs tests); test-runner adds no PostToolUse hook, so it never races the per-edit linter.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/hooks/lint-dispatch.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/hooks/lint-dispatch.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/hooks/test-runner.sh\"",
            "timeout": 300
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/hooks/test-runner.sh\"",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",

      "Bash(source *)",
      "Bash(. *)",
      "Bash(export *)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod +x ./scripts/*.sh)",

      "Bash(./scripts/*.sh)",
      "Bash(./scripts/*.sh *)",
      "Bash(bash ./scripts/*.sh *)",
      "Bash(sh ./scripts/*.sh *)",

      "Bash(make *)",
      "Bash(just *)",

      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git tag *)",

      "Bash(gh *)",

      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(pod install *)",

      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(goimports *)",
      "Bash(golangci-lint *)",
      "Bash(dlv *)",

      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(jest *)",
      "Bash(vitest *)",

      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pipx *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(poetry *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(isort *)",
      "Bash(mypy *)",
      "Bash(flake8 *)",
      "Bash(pylint *)",

      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(gsutil *)",
      "Bash(bq *)",

      "Bash(docker *)",
      "Bash(docker-compose *)",

      "WebFetch(domain:pub.dev)",
      "WebFetch(domain:dart.dev)",
      "WebFetch(domain:docs.flutter.dev)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:*.npmjs.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "WebFetch(domain:cloud.google.com)",
      "WebFetch(domain:cli.github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:stackoverflow.com)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(sudo *)",

      "Bash(gh repo delete *)",
      "Bash(gh secret *)",

      "Bash(aws * delete*)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 rb *)",
      "Bash(aws iam *)",

      "Bash(gcloud * delete*)",
      "Bash(gsutil rm *)",

      "Bash(docker push *)",
